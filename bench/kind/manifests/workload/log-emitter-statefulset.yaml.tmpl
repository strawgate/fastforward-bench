apiVersion: v1
kind: Service
metadata:
  name: log-emitter
  namespace: ${NAMESPACE}
  labels:
    app.kubernetes.io/name: log-emitter
spec:
  clusterIP: None
  selector:
    app.kubernetes.io/name: log-emitter
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: log-emitter
  namespace: ${NAMESPACE}
  labels:
    app.kubernetes.io/name: log-emitter
spec:
  serviceName: log-emitter
  replicas: ${POD_REPLICAS}
  selector:
    matchLabels:
      app.kubernetes.io/name: log-emitter
  template:
    metadata:
      labels:
        app.kubernetes.io/name: log-emitter
    spec:
      terminationGracePeriodSeconds: 5
      containers:
        - name: emitter
          image: python:3.12-alpine
          imagePullPolicy: IfNotPresent
          command: ["python", "/opt/emitter/emit.py"]
          env:
            - name: POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
            - name: BENCHMARK_ID
              value: "${BENCHMARK_ID}"
            - name: EPS_PER_POD
              value: "${EPS_PER_POD}"
          volumeMounts:
            - name: config
              mountPath: /opt/emitter
              readOnly: true
      volumes:
        - name: config
          configMap:
            name: log-emitter-config
