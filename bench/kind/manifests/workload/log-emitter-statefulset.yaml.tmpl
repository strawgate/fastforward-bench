apiVersion: v1
kind: Service
metadata:
  name: log-emitter
  namespace: ${NAMESPACE}
  labels:
    app.kubernetes.io/name: log-emitter
spec:
  clusterIP: None
  selector:
    app.kubernetes.io/name: log-emitter
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: log-emitter
  namespace: ${NAMESPACE}
  labels:
    app.kubernetes.io/name: log-emitter
spec:
  serviceName: log-emitter
  replicas: ${POD_REPLICAS}
  selector:
    matchLabels:
      app.kubernetes.io/name: log-emitter
  template:
    metadata:
      labels:
        app.kubernetes.io/name: log-emitter
    spec:
      terminationGracePeriodSeconds: 5
      containers:
        - name: emitter
          image: ${MEMAGENT_IMAGE}
          imagePullPolicy: IfNotPresent
          args: ["--config", "/etc/logfwd/config.yaml"]
          resources:
            requests:
              cpu: ${EMITTER_CPU_REQUEST}
              memory: ${EMITTER_MEMORY_REQUEST}
            limits:
              cpu: ${EMITTER_CPU_LIMIT}
              memory: ${EMITTER_MEMORY_LIMIT}
          ports:
            - name: diagnostics
              containerPort: 9090
          readinessProbe:
            httpGet:
              path: /ready
              port: diagnostics
            initialDelaySeconds: 3
            periodSeconds: 3
          env:
            - name: POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
            - name: BENCHMARK_ID
              value: "${BENCHMARK_ID}"
            - name: EPS_PER_POD
              value: "${EPS_PER_POD}"
          volumeMounts:
            - name: config
              mountPath: /etc/logfwd
              readOnly: true
      volumes:
        - name: config
          configMap:
            name: log-emitter-config
