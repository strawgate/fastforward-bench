apiVersion: v1
kind: ConfigMap
metadata:
  name: logfwd-capture-config
  namespace: ${NAMESPACE}
data:
  config.yaml: |
    server:
      diagnostics: 0.0.0.0:9090
    pipelines:
      capture:
        inputs:
          - type: otlp
            listen: 0.0.0.0:4318
        outputs:
          - type: file
            path: /var/lib/logfwd/capture.ndjson
            format: json
  capture-stats.py: |
    import json
    import os
    from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
    from pathlib import Path

    benchmark_id = os.environ.get("BENCHMARK_ID")
    capture_path = Path("/var/lib/logfwd/capture.ndjson")

    class Handler(BaseHTTPRequestHandler):
      def do_GET(self):
        if self.path != "/stats":
          self.send_response(404)
          self.end_headers()
          return
        payload = {
          "capture_rows_total": 0,
          "benchmark_rows_total": 0,
          "capture_size_bytes": 0,
          "benchmark_id": benchmark_id,
        }
        if capture_path.exists():
          payload["capture_size_bytes"] = capture_path.stat().st_size
          with capture_path.open("r", encoding="utf-8") as handle:
            for line in handle:
              line = line.strip()
              if not line:
                continue
              payload["capture_rows_total"] += 1
              if benchmark_id is None:
                payload["benchmark_rows_total"] += 1
                continue
              try:
                row = json.loads(line)
              except json.JSONDecodeError:
                continue
              if isinstance(row, dict) and row.get("benchmark_id") == benchmark_id:
                payload["benchmark_rows_total"] += 1
        body = json.dumps(payload, sort_keys=True).encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

      def log_message(self, format, *args):
        return

    server = ThreadingHTTPServer(("0.0.0.0", 8081), Handler)
    server.daemon_threads = True
    server.serve_forever()
