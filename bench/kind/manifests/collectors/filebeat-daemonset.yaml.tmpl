apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: filebeat-bench-collector
  namespace: ${NAMESPACE}
  labels:
    app.kubernetes.io/name: filebeat-bench-collector
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: filebeat-bench-collector
  template:
    metadata:
      labels:
        app.kubernetes.io/name: filebeat-bench-collector
    spec:
      automountServiceAccountToken: false
      tolerations:
        - operator: Exists
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: filebeat
          image: ${COLLECTOR_IMAGE}
          imagePullPolicy: IfNotPresent
          args: ["-e", "--strict.perms=false", "-c", "/etc/filebeat/filebeat.yml"]
          resources:
            requests:
              cpu: ${COLLECTOR_CPU_REQUEST}
              memory: ${COLLECTOR_MEMORY_REQUEST}
            limits:
              cpu: ${COLLECTOR_CPU_LIMIT}
              memory: ${COLLECTOR_MEMORY_LIMIT}
          securityContext:
            runAsNonRoot: false
            runAsUser: 0
            runAsGroup: 0
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: false
            capabilities:
              drop: ["ALL"]

          volumeMounts:
            - name: varlog
              mountPath: /var/log
              readOnly: true
            - name: config
              mountPath: /etc/filebeat
              readOnly: true
            - name: data
              mountPath: /var/lib/filebeat
      volumes:
        - name: varlog
          hostPath:
            path: /var/log
            type: Directory
        - name: config
          configMap:
            name: filebeat-bench-collector-config
        - name: data
          emptyDir: {}