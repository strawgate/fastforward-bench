apiVersion: v1
kind: ServiceAccount
metadata:
  name: vector-bench-collector
  namespace: ${NAMESPACE}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: vector-bench-collector-${NAMESPACE}
rules:
  - apiGroups: [""]
    resources: ["pods", "namespaces", "nodes"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: vector-bench-collector-${NAMESPACE}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: vector-bench-collector-${NAMESPACE}
subjects:
  - kind: ServiceAccount
    name: vector-bench-collector
    namespace: ${NAMESPACE}
---
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: vector-bench-collector
  namespace: ${NAMESPACE}
  labels:
    app.kubernetes.io/name: vector-bench-collector
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: vector-bench-collector
  template:
    metadata:
      labels:
        app.kubernetes.io/name: vector-bench-collector
    spec:
      automountServiceAccountToken: true
      serviceAccountName: vector-bench-collector
      tolerations:
        - operator: Exists
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: vector
          image: ${COLLECTOR_IMAGE}
          imagePullPolicy: IfNotPresent
          env:
            - name: VECTOR_SELF_NODE_NAME
              valueFrom:
                fieldRef:
                  fieldPath: spec.nodeName
          args:
            - --config
            - /etc/vector/vector.yaml
            - --quiet
          securityContext:
            runAsNonRoot: false
            runAsUser: 0
            runAsGroup: 0
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: false
            capabilities:
              drop: ["ALL"]
          readinessProbe:
            httpGet:
              path: /health
              port: 8686
            initialDelaySeconds: 3
            periodSeconds: 3
          volumeMounts:
            - name: varlog
              mountPath: /var/log
              readOnly: true
            - name: config
              mountPath: /etc/vector
              readOnly: true
            - name: data-dir
              mountPath: /vector-data-dir
      volumes:
        - name: varlog
          hostPath:
            path: /var/log
            type: Directory
        - name: config
          configMap:
            name: vector-bench-collector-config
        - name: data-dir
          emptyDir: {}
