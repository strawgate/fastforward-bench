apiVersion: v1
kind: ConfigMap
metadata:
  name: filebeat-bench-collector-config
  namespace: ${NAMESPACE}
data:
  filebeat.yml: |
    filebeat.inputs:
      - type: filestream
        id: bench-file
        enabled: true
        paths:
          - /var/log/pods/${NAMESPACE}_log-emitter-*/*/*.log
        parsers:
          - ndjson:
              target: ""
              overwrite_keys: true
              add_error_key: true
              message_key: message
        fields:
          benchmark_id: "${BENCHMARK_ID}"
        fields_under_root: false
    processors:
      - add_host_metadata:
          host: ""
    output.http:
      url: http://fastforward-capture.${NAMESPACE}.svc.cluster.local:8081/ingest
      method: post
      content_type: application/json
      bulk_max_size: 2048
      timeout: 30s
    http.enabled: false
    logging.level: error
    logging.to_stderr: false