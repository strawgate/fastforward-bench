apiVersion: v1
kind: ConfigMap
metadata:
  name: fluent-bit-bench-collector-config
  namespace: ${NAMESPACE}
data:
  fluent-bit.conf: |
    [SERVICE]
        flush           1
        log_level       error
        http_server     on
        http_listen     0.0.0.0
        http_port       2020
        parsers_file    /fluent-bit/etc/parsers.conf
        storage.path    /fluent-bit/state
        storage.sync    normal

    [INPUT]
        name            tail
        path            /var/log/pods/${NAMESPACE}_log-emitter-*/*/*.log
        parser          cri
        tag             bench.*
        read_from_head  true
        db              /fluent-bit/state/tail.db
        mem_buf_limit   256MB
        skip_long_lines on

    [FILTER]
        name            parser
        match           bench.*
        key_name        log
        parser          json
        reserve_data    off
        preserve_key    off

    [FILTER]
        name            grep
        match           bench.*
        regex           benchmark_id ${BENCHMARK_ID}

    [OUTPUT]
        name            http
        match           bench.*
        host            logfwd-capture.${NAMESPACE}.svc.cluster.local
        port            8081
        uri             /ingest
        format          json_lines
        json_date_key   timestamp

  parsers.conf: |
    [PARSER]
        name            cri
        format          regex
        regex           ^(?<time>[^ ]+) (?<stream>stdout|stderr) (?<logtag>[^ ]*) (?<log>.*)$

    [PARSER]
        name            json
        format          json
