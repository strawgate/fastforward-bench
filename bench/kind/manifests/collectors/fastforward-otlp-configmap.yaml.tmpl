apiVersion: v1
kind: ConfigMap
metadata:
  name: fastforward-bench-collector-config
  namespace: ${NAMESPACE}
data:
  config.yaml: |
    server:
      diagnostics: 0.0.0.0:9090
      log_level: error

    storage:
      data_dir: /var/lib/fastforward

    pipelines:
      default:
        inputs:
          - type: otlp
            listen: 0.0.0.0:4318

        transform: |
          SELECT
            benchmark_id,
            pod_name,
            stream_id,
            event_id,
            seq,
            event_created_unix_nano,
            level,
            body AS message,
            status,
            duration_ms,
            service
          FROM logs
          WHERE benchmark_id = '${BENCHMARK_ID}'

        outputs:
          - type: otlp
            endpoint: http://fastforward-capture.${NAMESPACE}.svc.cluster.local:4318/v1/logs
${COLLECTOR_BATCH_TARGET_BYTES_YAML}
