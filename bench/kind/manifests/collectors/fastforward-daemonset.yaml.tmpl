apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: fastforward-bench-collector
  namespace: ${NAMESPACE}
  labels:
    app.kubernetes.io/name: fastforward-bench-collector
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: fastforward-bench-collector
  template:
    metadata:
      labels:
        app.kubernetes.io/name: fastforward-bench-collector
    spec:
      automountServiceAccountToken: false
      tolerations:
        - operator: Exists
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: fastforward
          image: ${MEMAGENT_IMAGE}
          imagePullPolicy: IfNotPresent
          args: ["run", "--config", "/etc/fastforward/config.yaml"]
          resources:
            requests:
              cpu: ${COLLECTOR_CPU_REQUEST}
              memory: ${COLLECTOR_MEMORY_REQUEST}
            limits:
              cpu: ${COLLECTOR_CPU_LIMIT}
              memory: ${COLLECTOR_MEMORY_LIMIT}
          securityContext:
            runAsNonRoot: false
            runAsUser: 0
            runAsGroup: 0
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop: ["ALL"]
          readinessProbe:
            httpGet:
              path: /ready
              port: 9090
            initialDelaySeconds: 3
            periodSeconds: 3
          volumeMounts:
            - name: varlog
              mountPath: /var/log
              readOnly: true
            - name: config
              mountPath: /etc/fastforward
              readOnly: true
            - name: state
              mountPath: /var/lib/fastforward
      volumes:
        - name: varlog
          hostPath:
            path: /var/log
            type: Directory
        - name: config
          configMap:
            name: fastforward-bench-collector-config
        - name: state
          emptyDir: {}
